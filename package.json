{
  "name": "carmentis-indexer-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:common": "pnpm --filter @cmts-dev/carmentis-indexer-common build",
    "build:sdk": "pnpm --filter @cmts-dev/carmentis-indexer-sdk build",
    "build:indexer": "pnpm --filter @cmts-dev/carmentis-indexer build",
    "start": "pnpm --filter @cmts-dev/carmentis-indexer start",
    "start:dev": "pnpm --filter @cmts-dev/carmentis-indexer start:dev",
    "start:prod": "pnpm --filter @cmts-dev/carmentis-indexer start:prod",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "better-sqlite3",
      "cbor-extract",
      "sqlite3",
      "unrs-resolver"
    ]
  }
}
