{
  "name": "@cmts-dev/carmentis-indexer-sdk",
  "version": "0.0.1",
  "description": "Carmentis Indexer SDK",
  "author": "Carmentis SAS",
  "license": "Apache 2.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --filter @cmts-dev/carmentis-indexer-common build && tsdown"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@cmts-dev/carmentis-indexer-common": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^5.7.3"
  }
}